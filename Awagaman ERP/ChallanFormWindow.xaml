<Controls:MetroWindow x:Class="Awagaman_ERP.ChallanFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Awagaman_ERP"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        mc:Ignorable="d"
        Title="Delivery Challan Entry"
        Height="680"
        Width="960"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="#EEEEEE"
        BorderThickness="1"
        BorderBrush="#18609A">
    <Controls:MetroWindow.Resources>
        <SolidColorBrush x:Key="ThemeBlue" Color="#18609A" />
        <SolidColorBrush x:Key="ThemeGreen" Color="#00B08B" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#DDDDDD" />
        <SolidColorBrush x:Key="StrongTextBrush" Color="#333333" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#666666" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ThemeBlue}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource StrongTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CurrencyInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="CurrencyTextBox_PreviewMouseLeftButtonDown" />
            <EventSetter Event="GotKeyboardFocus" Handler="CurrencyTextBox_GotKeyboardFocus" />
        </Style>

        <Style x:Key="InputDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="26" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="IsTextSearchEnabled" Value="False" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ThemeGreen}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Controls:MetroWindow.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,12" Background="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DELIVERY CHALLAN ENTRY" Foreground="{StaticResource ThemeBlue}" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="Create or edit logistics challan records" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total Due:" FontSize="12" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding Due, StringFormat=₹{0:N2}}" FontSize="20" FontWeight="Bold" Foreground="#DC2626" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Form Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel>
                <UniformGrid Columns="2" Margin="0,0,0,12">
                    
                    <!-- Trip Basics -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0" Background="#F5FAFF" BorderBrush="#D5E6F6">
                        <StackPanel>
                            <TextBlock Text="Trip Basics" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Challan No" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox x:Name="ChallanNoBox" Text="{Binding ChallanNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" LostFocus="ChallanNo_LostFocus" />
                                    <TextBlock x:Name="ChallanDuplicateWarning" Text="⚠ This challan number already exists" FontSize="11" Foreground="#E53935" Visibility="Collapsed" Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Date" Style="{StaticResource FieldLabelStyle}" />
                                    <DatePicker SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputDatePickerStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Agent / Broker" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding BrokerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="LR No. (Multiple)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding LRNumber, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource InputTextBoxStyle}" 
                                             Height="46" 
                                             AcceptsReturn="True" 
                                             TextWrapping="Wrap" 
                                             VerticalScrollBarVisibility="Auto" 
                                             VerticalContentAlignment="Top" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Origin (From)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding From, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="Destination (To)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding To, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Vehicle & Driver -->
                    <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0" Background="#F7FFF8" BorderBrush="#CFEBD3">
                        <StackPanel>
                            <TextBlock Text="Vehicle &amp; Driver Details" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Vehicle No" Style="{StaticResource FieldLabelStyle}" />
                                    <Grid>
                                        <TextBox x:Name="VehicleNumberBox" Text="{Binding VehicleNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" TextChanged="VehicleNumberBox_TextChanged" LostFocus="VehicleNumberBox_LostFocus" PreviewKeyDown="VehicleNumberBox_PreviewKeyDown" />
                                        <Popup x:Name="VehiclePopup" PlacementTarget="{Binding ElementName=VehicleNumberBox}" Placement="Bottom" StaysOpen="False" Width="{Binding ActualWidth, ElementName=VehicleNumberBox}">
                                            <Border BorderBrush="#AAA" BorderThickness="1" Background="White" CornerRadius="4">
                                                <ListBox x:Name="VehicleSuggestionList" MaxHeight="220" FontSize="12" SelectionChanged="VehicleSuggestionList_SelectionChanged" DisplayMemberPath="VehicleNumber" />
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Owner Name" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding OwnerName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Driver Name" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding DriverName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Driver Mobile" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding DriverMobile, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Licence No" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding LicenceNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="PAN" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding PAN, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Engine No" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding EngineNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Chassis No" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding ChassisNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="4" Grid.Column="0">
                                    <TextBlock Text="Policy No" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding PolicyNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="2">
                                    <TextBlock Text="Vehicle Type" Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox Text="{Binding VehicleType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputComboBoxStyle}" IsEditable="True">
                                        <ComboBoxItem Content="Open" />
                                        <ComboBoxItem Content="Container" />
                                        <ComboBoxItem Content="Trailer" />
                                        <ComboBoxItem Content="Tanker" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,12">
                    
                    <!-- Financials & Advances -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0" Background="#FFF8F4" BorderBrush="#F0D8C8">
                        <StackPanel>
                            <TextBlock Text="Freight &amp; Advances" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Lorry Hire (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding LorryHire, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Less TDS (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding LessTDS, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Total Advance (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding AdvanceAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Advance Date" Style="{StaticResource FieldLabelStyle}" />
                                    <DatePicker SelectedDate="{Binding AdvanceDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputDatePickerStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Advance NEFT (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding AdvanceNEFT, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Advance Cash (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding AdvanceCash, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Paid To" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding PaidTo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                </StackPanel>

                                <!-- Live Balance Box -->
                                <Border Grid.Row="4" Grid.ColumnSpan="3" Background="#E8F4FD" BorderBrush="#B6D8F2" BorderThickness="1" Padding="12,8" Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="Current Balance:" Foreground="#18609A" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding Balance, StringFormat=₹{0:N2}}" FontWeight="Bold" FontSize="16" Foreground="#18609A" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Deductions & Settlement -->
                    <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0" Background="#F4FBF8" BorderBrush="#CEE8DC">
                        <StackPanel>
                            <TextBlock Text="Deductions &amp; Settlements" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Detention (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding Detention, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Hamali (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding Hamali, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Deduction (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding Deduction, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Bal Paid NEFT (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding BalancePaidNEFT, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="Bal Paid Cash (₹)" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding BalancePaidCash, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock Text="Bal Paid Date" Style="{StaticResource FieldLabelStyle}" />
                                    <DatePicker SelectedDate="{Binding BalancePaidDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputDatePickerStyle}" />
                                </StackPanel>

                                <Grid Grid.Row="3" Grid.ColumnSpan="3" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Bill Amount" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox Text="{Binding BillAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Margin" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBox Text="{Binding Margin, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CurrencyInputTextBoxStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Remarks -->
                <Border Style="{StaticResource CardStyle}" Background="#F9F6FF" BorderBrush="#DDD0F0">
                    <StackPanel>
                        <TextBlock Text="Remarks &amp; Notes" Style="{StaticResource SectionHeaderStyle}" />
                        <TextBox Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                                 BorderBrush="#CCCCCC" BorderThickness="1" Padding="8" FontSize="12" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Margin="0,12,0,0" Background="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Padding="12,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="100" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click" Margin="0,0,8,0" />
                <Button Content="Save Challan" Width="120" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Controls:MetroWindow>
