<Controls:MetroWindow x:Class="Awagaman_ERP.PartyLedgerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Party Ledger" Height="600" Width="900" WindowStartupLocation="CenterScreen"
        Icon="logo.png"
        Background="#F3F4F6">
    <Controls:MetroWindow.Resources>
        <SolidColorBrush x:Key="ThemeBlue" Color="#18609A" />
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB" />
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
    </Controls:MetroWindow.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Party Ledger" FontSize="20" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" Width="200" Height="26" FontSize="12" Padding="4,2" BorderBrush="#CCC" Margin="0,0,8,0" />
                <Button Content="Close" Background="#E0E0E0" BorderThickness="0" Padding="16,6" FontSize="12" Click="Close_Click" />
            </StackPanel>
        </Grid>
        <DataGrid Grid.Row="1" ItemsSource="{Binding}" AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="White" BorderThickness="1" BorderBrush="#DDD" RowHeight="30"
                  GridLinesVisibility="All" HeadersVisibility="All"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sr." Binding="{Binding Sr}" Width="40" IsReadOnly="True" />
                <DataGridTextColumn Header="Party Name" Binding="{Binding PartyName}" Width="200" FontWeight="SemiBold" />
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="300" />
                <DataGridTextColumn Header="GST No." Binding="{Binding GSTNo}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Controls:MetroWindow>
