<Controls:MetroWindow x:Class="Awagaman_ERP.CommentPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="Comments"
        Height="400" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA"
        BorderThickness="1" BorderBrush="#18609A">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Comments" FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,0,0,8" />
        <ListBox Grid.Row="1" x:Name="CommentList" BorderThickness="1" BorderBrush="#DDD" Background="White" FontSize="12" Margin="0,0,0,8"
                 ItemsSource="{Binding}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="4,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DisplayText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="✕" FontSize="10" Width="20" Height="20" Padding="0"
                                    Background="Transparent" Foreground="#E53935" BorderThickness="0" Cursor="Hand"
                                    Click="DeleteComment_Click" Tag="{Binding}" Margin="4,0,0,0" ToolTip="Delete" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <TextBox Grid.Row="2" x:Name="CommentTextBox" Height="60" AcceptsReturn="True" TextWrapping="Wrap" BorderBrush="#CCC" FontSize="12" Padding="4" VerticalScrollBarVisibility="Auto" />
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Add Comment" Width="100" Height="30" Background="#18609A" Foreground="White" BorderThickness="0" Margin="0,0,8,0" Click="AddComment_Click" />
            <Button Content="Close" Width="80" Height="30" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Controls:MetroWindow>
