<Controls:MetroWindow x:Class="Awagaman_ERP.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:local="clr-namespace:Awagaman_ERP"

        xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"

        xmlns:dgx="urn:tom-englert.de/DataGridExtensions"

        mc:Ignorable="d"

        x:Name="Root"

        Title="Awagaman ERP - Challan Ledger" 

        Height="650" Width="1300"

        WindowState="Maximized"

        WindowStartupLocation="CenterScreen"

        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Controls:MetroWindow.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <ControlTemplate x:Key="MultiFilterTemplate">

            <dgx:MultipleChoiceFilter Filter="{Binding Path=Filter, RelativeSource={RelativeSource FindAncestor, AncestorType=dgx:DataGridFilterColumnControl}}"/>

        </ControlTemplate>



        <!-- Colors based on reference image -->

        <SolidColorBrush x:Key="ThemeBlue" Color="#18609A" />

        <SolidColorBrush x:Key="ThemeGreen" Color="#00B08B" />

        <SolidColorBrush x:Key="SidebarBg" Color="#1E659D" />

        <SolidColorBrush x:Key="AppBg" Color="#EEEEEE" />

        <SolidColorBrush x:Key="TextDark" Color="#333333" />

        <SolidColorBrush x:Key="TextMuted" Color="#777777" />

        <SolidColorBrush x:Key="BorderLight" Color="#DDDDDD" />



        <!-- Sidebar Button Style -->

        <Style x:Key="SidebarButtonStyle" TargetType="Button">

            <Setter Property="Background" Value="Transparent" />

            <Setter Property="Foreground" Value="White" />

            <Setter Property="BorderThickness" Value="0" />

            <Setter Property="Height" Value="60" />

            <Setter Property="Cursor" Value="Hand" />

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="bg" Background="{TemplateBinding Background}">

                            <Grid>

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="*" />

                                    <ColumnDefinition Width="Auto" />

                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                                    <!-- Use Text for icon placeholder -->

                                    <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" FontFamily="Segoe UI Symbol" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,4" />

                                    <TextBlock Text="{TemplateBinding Content}" FontSize="12" HorizontalAlignment="Center" />

                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="+" Foreground="#88B1D4" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />

                            </Grid>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="bg" Property="Background" Value="#135284" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- Tab Style -->

        <Style x:Key="TabButtonStyle" TargetType="Button">

            <Setter Property="Background" Value="Transparent" />

            <Setter Property="Foreground" Value="#888888" />

            <Setter Property="BorderThickness" Value="0,0,0,3" />

            <Setter Property="BorderBrush" Value="Transparent" />

            <Setter Property="FontSize" Value="13" />

            <Setter Property="Padding" Value="20,12" />

            <Setter Property="Cursor" Value="Hand" />

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Foreground" Value="{StaticResource ThemeBlue}" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <Style x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">

            <Setter Property="Foreground" Value="{StaticResource ThemeBlue}" />

            <Setter Property="BorderBrush" Value="{StaticResource ThemeBlue}" />

        </Style>



        <!-- Green Action Button Style -->

        <Style x:Key="GreenButtonStyle" TargetType="Button">

            <Setter Property="Background" Value="{StaticResource ThemeGreen}" />

            <Setter Property="Foreground" Value="White" />

            <Setter Property="BorderThickness" Value="0" />

            <Setter Property="Padding" Value="12,6" />

            <Setter Property="FontSize" Value="12" />

            <Setter Property="Cursor" Value="Hand" />

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}" CornerRadius="2">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Background" Value="#009A7A" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <!-- ComboBox placeholder style -->

        <Style x:Key="FilterComboBox" TargetType="ComboBox">

            <Setter Property="Width" Value="110" />

            <Setter Property="Height" Value="26" />

            <Setter Property="Margin" Value="4,0" />

            <Setter Property="FontSize" Value="12" />

        </Style>



        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">

            <Setter Property="Background" Value="#F8F8F8"/>

            <Setter Property="Foreground" Value="#333333"/>

            <Setter Property="FontWeight" Value="Bold"/>

            <Setter Property="Padding" Value="10,12"/>

            <Setter Property="BorderBrush" Value="#DDDDDD"/>

            <Setter Property="BorderThickness" Value="0,1,0,1"/>

        </Style>





    </Controls:MetroWindow.Resources>



    <Grid Background="{StaticResource AppBg}">

        <Grid.ColumnDefinitions>

            <!-- Sidebar -->

            <ColumnDefinition Width="100" x:Name="SidebarColumn" />

            <!-- Main Content -->

            <ColumnDefinition Width="*" />

        </Grid.ColumnDefinitions>



        <!-- Left Sidebar -->

        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto" />

                    <RowDefinition Height="*" />

                </Grid.RowDefinitions>

                

                <!-- Profile Area -->

                <Border Grid.Row="0" Background="White" Padding="0,16" Margin="0,0,0,1">

                    <StackPanel>

                        <Border Width="40" Height="40" CornerRadius="20" Background="#FF8C00" HorizontalAlignment="Center">

                            <TextBlock Text="SU" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        </Border>

                        <TextBlock Text="Subhash Kumar" Foreground="{StaticResource ThemeBlue}" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" />

                    </StackPanel>

                </Border>



                <!-- Navigation Links -->

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">

                    <StackPanel>

                        <Button Content="Sales" Tag="📊" Style="{StaticResource SidebarButtonStyle}" />

                        <Button Content="Delivery Challans" Tag="🚚" Style="{StaticResource SidebarButtonStyle}" Foreground="{StaticResource ThemeBlue}" Background="#F3F4F6" />

                        <Button Content="Purchase" Tag="🛒" Style="{StaticResource SidebarButtonStyle}" />

                        <Button Content="Returns" Tag="↩" Style="{StaticResource SidebarButtonStyle}" />

                        <Button Content="Master" Tag="≡" Style="{StaticResource SidebarButtonStyle}" />

                        <Button Content="Imports" Tag="📥" Style="{StaticResource SidebarButtonStyle}" />
                        <Button Content="Reconciliation" Tag="📄" Style="{StaticResource SidebarButtonStyle}" />
                        <Button Content="Reports" Tag="⊞" Style="{StaticResource SidebarButtonStyle}" />

                    </StackPanel>

                </ScrollViewer>

            </Grid>

        </Border>



        <!-- Main Workspace -->

        <Grid Grid.Column="1" Margin="24">

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto" /> <!-- Title -->

                <RowDefinition Height="*" />    <!-- White Card -->

            </Grid.RowDefinitions>



            <!-- Page Title Area -->

            <Grid Grid.Row="0" Margin="0,0,0,16">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <Button Content="â˜°" FontSize="18" Background="Transparent" BorderThickness="0" Foreground="#555555" Margin="0,0,16,0" Cursor="Hand" Click="ToggleSidebar_Click" ToolTip="Toggle Sidebar" />

                    <TextBlock x:Name="PageTitle" Text="Delivery Challan List" FontSize="18" Foreground="#555555" FontWeight="SemiBold" VerticalAlignment="Center" />

                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <TextBlock Text="ðŸ  / Dashboard" Foreground="#888888" FontSize="12" />

                </StackPanel>

            </Grid>



            <!-- White Main Card -->

            <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderLight}" BorderThickness="1">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto" /> <!-- Tabs -->

                        <RowDefinition Height="Auto" /> <!-- Summary & Add Button -->

                        <RowDefinition Height="Auto" /> <!-- Search & Filter -->

                        <RowDefinition Height="Auto" /> <!-- Show Entries -->

                        <RowDefinition Height="*" />    <!-- DataGrid -->

                    </Grid.RowDefinitions>



                    <!-- Row 0: Tabs -->

                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="TabDashboard" Content="Dashboard" Style="{StaticResource ActiveTabButtonStyle}" Width="160" Click="OpenDashboard_Click" />
                                <Button x:Name="TabBillLedger" Content="Bill Ledger" Style="{StaticResource TabButtonStyle}" Width="160" Click="OpenBillLedger_Click" />
                                <Button x:Name="TabCBSLedger" Content="CBS" Style="{StaticResource TabButtonStyle}" Width="120" Click="OpenCBSLedger_Click" />
                                <Button x:Name="TabPartyLedger" Content="Party Ledger" Style="{StaticResource TabButtonStyle}" Width="160" Click="OpenPartyLedgerTab_Click" />
                                <Button x:Name="TabVehicleLedger" Content="Vehicle Ledger" Style="{StaticResource TabButtonStyle}" Width="160" Click="OpenVehicleLedgerTab_Click" />
                                <Button x:Name="TabLRLedger" Content="LR Ledger" Style="{StaticResource TabButtonStyle}" Width="160" Click="OpenLRLedger_Click" />
                                <Button x:Name="TabDeliveryChallans" Content="Delivery Challans" Style="{StaticResource TabButtonStyle}" Width="160" Click="OpenDeliveryChallans_Click" />
                                <Button x:Name="TabTrackingLedger" Content="Tracking Ledger" Style="{StaticResource TabButtonStyle}" Width="160" Click="OpenTrackingLedger_Click" />
                            </StackPanel>

                            <Button Grid.Column="1" Content="Reset Data" Background="#C62828" Foreground="White" BorderThickness="0" Padding="12,6" FontSize="12" Cursor="Hand" Click="ResetAllData_Click" ToolTip="Delete all ledger data" Margin="8,8,12,8" VerticalAlignment="Center" />
                        </Grid>
                    </Border>



                    <!-- Dashboard View -->
                    <Grid x:Name="DashboardView" Grid.Row="1" Grid.RowSpan="4">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F7FAFF" Offset="0" />
                                <GradientStop Color="#EEF4FF" Offset="0.52" />
                                <GradientStop Color="#EAF7F4" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>

                        <Grid.Resources>
                            <Style x:Key="DashboardCardStyle" TargetType="Border">
                                <Setter Property="CornerRadius" Value="18" />
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderBrush" Value="#DDE6F4" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Padding" Value="20" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="2" Color="#1A335A" Opacity="0.10" />
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <Style x:Key="DashboardMetricLabel" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#5A6B82" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                            <Style x:Key="DashboardMetricValue" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#13233B" />
                                <Setter Property="FontSize" Value="30" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                            <Style x:Key="DashboardMetricHint" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#71839A" />
                                <Setter Property="FontSize" Value="11" />
                            </Style>
                            <Style x:Key="DashboardSectionTitle" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#153B63" />
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                            <Style x:Key="DashboardSectionSubTitle" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#64748B" />
                                <Setter Property="FontSize" Value="11" />
                            </Style>
                            <Style x:Key="DashboardGridStyle" TargetType="DataGrid">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HeadersVisibility" Value="Column" />
                                <Setter Property="GridLinesVisibility" Value="Horizontal" />
                                <Setter Property="HorizontalGridLinesBrush" Value="#E8EEF6" />
                                <Setter Property="RowBackground" Value="White" />
                                <Setter Property="AlternatingRowBackground" Value="#F8FBFF" />
                                <Setter Property="AlternationCount" Value="2" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="RowHeight" Value="30" />
                                <Setter Property="CanUserAddRows" Value="False" />
                                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
                                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                                <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
                                <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
                            </Style>
                            <Style x:Key="DashboardTableRowStyle" TargetType="DataGridRow">
                                <Setter Property="MinHeight" Value="34" />
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F9FF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E8F0FF" />
                                        <Setter Property="BorderBrush" Value="#B5C9F5" />
                                        <Setter Property="BorderThickness" Value="1" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style x:Key="DashboardTableCellStyle" TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,6" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#DCE9FF" />
                                        <Setter Property="Foreground" Value="#102A43" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F9FF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style x:Key="DashboardActionButtonStyle" TargetType="Button">
                                <Setter Property="Background" Value="#7C3AED" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="14,0" />
                                <Setter Property="Height" Value="26" />
                                <Setter Property="MinWidth" Value="0" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="13" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Grid.Resources>

                        <Grid Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="DashboardDueCard" Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Background="#FFF7ED"
                                        Cursor="Hand" ToolTip="Open challan ledger with only due rows" MouseLeftButtonUp="DashboardDueCard_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Background="#F97316" CornerRadius="12" HorizontalAlignment="Left" Padding="10,5">
                                            <TextBlock Text="Cash flow" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                            <TextBlock Text="Total Due" Style="{StaticResource DashboardMetricLabel}" Foreground="#C2410C" />
                                            <TextBlock x:Name="DashboardTotalDue" Text="₹ 0.00" Style="{StaticResource DashboardMetricValue}" Foreground="#9A3412" Margin="0,4,0,0" />
                                            <TextBlock x:Name="DashboardTotalChallans" Text="0 Challans" Style="{StaticResource DashboardMetricHint}" Foreground="#C2410C" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource DashboardCardStyle}" Background="#ECFDF3">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Background="#16A34A" CornerRadius="12" HorizontalAlignment="Left" Padding="10,5">
                                            <TextBlock Text="Bills" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                            <TextBlock Text="Outstanding" Style="{StaticResource DashboardMetricLabel}" Foreground="#166534" />
                                            <TextBlock x:Name="DashboardOutstanding" Text="₹ 0.00" Style="{StaticResource DashboardMetricValue}" Foreground="#14532D" Margin="0,4,0,0" />
                                            <TextBlock Text="Amount pending across bill records" Style="{StaticResource DashboardMetricHint}" Foreground="#166534" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="4" Style="{StaticResource DashboardCardStyle}" Background="#FFFBEB">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Background="#D97706" CornerRadius="12" HorizontalAlignment="Left" Padding="10,5">
                                            <TextBlock Text="Follow-up" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                            <TextBlock Text="Pending Bills" Style="{StaticResource DashboardMetricLabel}" Foreground="#B45309" />
                                            <TextBlock x:Name="DashboardPendingBill" Text="0" Style="{StaticResource DashboardMetricValue}" Foreground="#92400E" Margin="0,4,0,0" />
                                            <TextBlock Text="Delivered LR entries still waiting for a bill" Style="{StaticResource DashboardMetricHint}" Foreground="#B45309" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="6" Style="{StaticResource DashboardCardStyle}" Background="#F5F3FF">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Background="#7C3AED" CornerRadius="12" HorizontalAlignment="Left" Padding="10,5">
                                            <TextBlock Text="Bookings" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                            <TextBlock Text="New Bookings" Style="{StaticResource DashboardMetricLabel}" Foreground="#6D28D9" />
                                            <TextBlock x:Name="DashboardNewBookings" Text="0" Style="{StaticResource DashboardMetricValue}" Foreground="#5B21B6" Margin="0,4,0,0" />
                                            <TextBlock Text="Challans without an LR number yet" Style="{StaticResource DashboardMetricHint}" Foreground="#6D28D9" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource DashboardCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="New Bookings" Style="{StaticResource DashboardSectionTitle}" />
                                                <TextBlock Text="Challans that need an LR number assigned." Style="{StaticResource DashboardSectionSubTitle}" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#F3E8FF" CornerRadius="999" Padding="12,5" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DashboardNewBookings.Text, ElementName=DashboardNewBookings}" Foreground="#6D28D9" FontSize="11" FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                        <DataGrid x:Name="NewBookingGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                                                  Style="{StaticResource DashboardGridStyle}"
                                                  RowStyle="{StaticResource DashboardTableRowStyle}"
                                                  CellStyle="{StaticResource DashboardTableCellStyle}"
                                                  SelectionUnit="FullRow"
                                                  CellEditEnding="NewBookingGrid_CellEditEnding">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                                    <Setter Property="Background" Value="#F6F0FF" />
                                                    <Setter Property="Foreground" Value="#5B21B6" />
                                                    <Setter Property="Padding" Value="12,9" />
                                                </Style>
                                                <Style TargetType="ScrollBar">
                                                    <Style.Triggers>
                                                        <Trigger Property="Orientation" Value="Vertical">
                                                            <Setter Property="Width" Value="14" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Challan No" Binding="{Binding ChallanNumber}" Width="120" FontWeight="SemiBold" />
                                                <DataGridTextColumn Header="From" Binding="{Binding From}" Width="90" />
                                                <DataGridTextColumn Header="To" Binding="{Binding To}" Width="90" />
                                                <DataGridTextColumn Header="Vehicle No" Binding="{Binding VehicleNumber}" Width="110" />
                                                <DataGridTextColumn Header="Broker" Binding="{Binding BrokerName}" Width="130" />
                                                <DataGridTemplateColumn Header="" Width="112">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="Create LR" Style="{StaticResource DashboardActionButtonStyle}" ToolTip="Create LR"
                                                                    Cursor="Hand" Click="DashboardMakeLR_Click" Tag="{Binding}"
                                                                    HorizontalAlignment="Right" Margin="0,0,8,0" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource DashboardCardStyle}" Background="#FFFDF5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Pending Bills" Style="{StaticResource DashboardSectionTitle}" />
                                                <TextBlock Text="Delivered LR entries that still need billing." Style="{StaticResource DashboardSectionSubTitle}" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#FFEDD5" CornerRadius="999" Padding="12,5" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DashboardPendingBill.Text, ElementName=DashboardPendingBill}" Foreground="#B45309" FontSize="11" FontWeight="Bold" />
                                            </Border>
