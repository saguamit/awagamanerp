                                <Button Content="↻" Background="{StaticResource ThemeGreen}" Foreground="White" BorderThickness="0" Width="26" Height="26" Margin="4,0" Cursor="Hand" Click="LRRefresh_Click" ToolTip="Clear Filters &amp; Search" />

                                <Button Content="🗑" Background="#E53935" Foreground="White" BorderThickness="0" Width="26" Height="26" Margin="4,0" Cursor="Hand" Click="LRDeleteSelected_Click" ToolTip="Delete Selected" />

                                <Button Content="📂" Background="#1565C0" Foreground="White" BorderThickness="0" Width="26" Height="26" Margin="4,0" Cursor="Hand" Click="ImportLR_Click" ToolTip="Import LR from CSV" />

                                <Button Content="📇" Background="#7B1FA2" Foreground="White" BorderThickness="0" Width="26" Height="26" Margin="4,0" Cursor="Hand" Click="OpenPartyLedger_Click" ToolTip="Party Ledger" />

                                <Button Content="📋" Background="#00B08B" Foreground="White" BorderThickness="0" Width="26" Height="26" Margin="4,0" Cursor="Hand" Click="CreateBillFromLR_Click" ToolTip="Create Bill from selected LR" />

                                <TextBlock x:Name="LRRecordCountText" Text="Loading..." FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="16,0,0,0" />

                            </StackPanel>

                        </Border>



                        <Grid Grid.Row="2">

                            <Grid.RowDefinitions>

                                <RowDefinition Height="*" />

                                <RowDefinition Height="Auto" />

                            </Grid.RowDefinitions>

                                <local:CustomDataGrid ItemsSource="{Binding PagedEntries}" AutoGenerateColumns="False" CanUserAddRows="False" x:Name="LRLedgerGrid"
                                          ScrollViewer.HorizontalScrollBarVisibility="Visible" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Pixel"
                                          Background="White" BorderThickness="0" RowHeight="30" RowHeaderWidth="28" HeadersVisibility="All"
                                          GridLinesVisibility="All" HorizontalGridLinesBrush="#E5E7EB" VerticalGridLinesBrush="#EEF2F7"
                                          RowBackground="White" FontSize="12" SelectionUnit="CellOrRowHeader"

                                           SelectedCellsChanged="LRLedgerGrid_SelectedCellsChanged"
                                           BeginningEdit="LRLedgerGrid_BeginningEdit"
                                           PreparingCellForEdit="LRLedgerGrid_PreparingCellForEdit"
                                           CellEditEnding="LRLedgerGrid_CellEditEnding"
                                           PreviewKeyDown="DataGrid_PreviewKeyDown"
                                           PreviewMouseLeftButtonDown="LRLedgerGrid_PreviewMouseLeftButtonDown"
                                           PreviewMouseDoubleClick="LRLedgerGrid_PreviewMouseDoubleClick"
                                           PreviewMouseMove="LRLedgerGrid_PreviewMouseMove"
                                           PreviewMouseLeftButtonUp="LRLedgerGrid_PreviewMouseLeftButtonUp"
                                           PreviewMouseRightButtonUp="LRLedgerGrid_PreviewMouseRightButtonUp"
                                           Sorting="LRLedgerGrid_SortingMenuOnly"

                                           ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderBrush" Value="#EEF2F7" />
                                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#DBEAFE" />
                                                    <Setter Property="BorderBrush" Value="#93C5FD" />
                                                    <Setter Property="Foreground" Value="#0F172A" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Resources>
                                        <Style TargetType="ScrollBar">
                                            <Style.Triggers>
                                                <Trigger Property="Orientation" Value="Vertical">
                                                    <Setter Property="Width" Value="16" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>

                                     <DataGrid.Columns>

                                        <DataGridTextColumn Header="Sr." Binding="{Binding Sr}" Width="35" IsReadOnly="True" />

                                        <DataGridTemplateColumn Header="LR No." Width="100" SortMemberPath="LRNo">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding LRNo}" FontWeight="SemiBold" VerticalAlignment="Center" Padding="4,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasComments}" Value="True">
                                                                        <Setter Property="Background" Value="#FFF3E0" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <TextBlock.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="View / Add Comment" Click="AddLRComment_Click" Tag="{Binding}" />
                                                            </ContextMenu>
                                                        </TextBlock.ContextMenu>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd-MMM-yyyy}" Width="90" />

                                        <DataGridTextColumn Header="Consignor Name" Binding="{Binding ConsignorName}" Width="150" />

                                        <DataGridTextColumn Header="Consignor Address" Binding="{Binding ConsignorAddress}" Width="150" />

                                        <DataGridTextColumn Header="Consignor GST" Binding="{Binding ConsignorGST}" Width="110">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="CharacterCasing" Value="Upper" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Consignee Name" Binding="{Binding ConsigneeName}" Width="150" />

                                        <DataGridTextColumn Header="Consignee Address" Binding="{Binding ConsigneeAddress}" Width="150" />

                                        <DataGridTextColumn Header="Consignee GST" Binding="{Binding ConsigneeGST}" Width="110">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="CharacterCasing" Value="Upper" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="From" Binding="{Binding From}" Width="90" IsReadOnly="True" />

                                        <DataGridTextColumn Header="To" Binding="{Binding To}" Width="90" IsReadOnly="True" />

                                        <DataGridTextColumn Header="Vehicle No." Binding="{Binding VehicleNo}" Width="100" IsReadOnly="True" />

                                        <DataGridTextColumn Header="Type" Binding="{Binding VehicleType}" Width="80" IsReadOnly="True" />

                                        <DataGridTextColumn Header="L" Binding="{Binding SizeL, StringFormat=0.####################}" Width="60">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="W" Binding="{Binding SizeW, StringFormat=0.####################}" Width="60">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="H" Binding="{Binding SizeH, StringFormat=0.####################}" Width="60">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Actual Weight" Binding="{Binding ActualWeight, StringFormat=0.####################}" Width="100">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Charged Weight" Binding="{Binding ChargedWeight, StringFormat=0.####################}" Width="110">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="No. of Pkg" Binding="{Binding PKG}" Width="80">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Pkg Type" Binding="{Binding PkgType}" Width="90" />

                                        <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="120" />

                                        <DataGridTextColumn Header="Invoice" Binding="{Binding Invoice}" Width="100" />
                                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="100" />

                                        <DataGridTextColumn Header="CH No." Binding="{Binding CHNo}" Width="90" IsReadOnly="True" />

                                        <DataGridTextColumn Header="Total Freight" Binding="{Binding TotalFreight}" Width="90" FontWeight="SemiBold" Foreground="#18609A">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Hamali" Binding="{Binding Hamali}" Width="80">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Detention" Binding="{Binding Detention}" Width="80">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Others" Binding="{Binding Others}" Width="80">
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <EventSetter Event="GotKeyboardFocus" Handler="LRNumericTextBox_GotKeyboardFocus" />
                                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LRNumericTextBox_PreviewMouseLeftButtonDown" />
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Total Bill" Binding="{Binding TotalBill}" Width="90" FontWeight="SemiBold" Foreground="#1D4ED8" IsReadOnly="True" />

                                        <DataGridTextColumn Header="Bill No." Binding="{Binding BillNo}" Width="90" />

                                        <DataGridTextColumn Header="Bill Date" Binding="{Binding BillDate, StringFormat=dd-MMM-yyyy}" Width="90" />

                                        <DataGridTextColumn Header="Bill Party" Binding="{Binding BillParty}" Width="120" />

                                        <DataGridTextColumn Header="Broker" Binding="{Binding Broker}" Width="110" />

                                        <DataGridTextColumn Header="Frt Type" Binding="{Binding FrtType}" Width="80" />

                                        <DataGridTextColumn Header="To Pay/To Be Billed" Binding="{Binding PayType}" Width="130" />

                                        <DataGridTextColumn Header="comm" Binding="{Binding Comm}" Width="70" />

                                        <DataGridTextColumn Header="Paid" Binding="{Binding Paid}" Width="60" />

                                    </DataGrid.Columns>

                                </local:CustomDataGrid>

                            <Border Grid.Row="1" Background="White" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="10,8">

                                <Grid>

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="Auto" />

                                        <ColumnDefinition Width="*" />

                                        <ColumnDefinition Width="Auto" />

                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="LRSearchedRecordsTextBlock" Text="{Binding FilteredEntriesCount, StringFormat='Records: {0}'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center" />

                                    <TextBlock x:Name="LRSelectedSumTextBlock" Grid.Column="1" Text="" FontSize="13" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" />

                                    <TextBlock x:Name="LRSearchedTotalDueTextBlock" Grid.Column="2" Text="{Binding FilteredTotalBalance, StringFormat='Filtered Balance: ₹ {0:N2}'}" FontSize="13" Foreground="#DC2626" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Visibility="Collapsed" />

                                </Grid>

                            </Border>

                        </Grid>

                    </Grid>

                    <!-- Tracking Ledger View -->
                    <Grid x:Name="TrackingLedgerView" Grid.Row="1" Grid.RowSpan="4" Visibility="Collapsed" Background="White" DataContext="{Binding TrackingVM, RelativeSource={RelativeSource FindAncestor, AncestorType=local:MainWindow}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1" Padding="16,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,40,0">
                                        <TextBlock Text="Total Records" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding FilteredEntriesCount}" FontSize="13" Foreground="{StaticResource TextDark}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="TrackingSelectedInfo" FontSize="13" FontWeight="SemiBold" Foreground="#10B981" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1" Padding="16,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Search:" FontSize="12" Foreground="{StaticResource TextDark}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" />
                                <TextBox x:Name="TrackingSearchBox" TextChanged="TrackingSearchBox_TextChanged" Width="200" Height="26" BorderBrush="{StaticResource BorderLight}" FontSize="12" Padding="4,2" Margin="0,0,16,0" />
                                <ComboBox x:Name="StatusFilterCombo" Width="130" Height="26" FontSize="12" Margin="0,0,16,0" SelectionChanged="StatusFilterCombo_SelectionChanged">
                                    <ComboBoxItem Content="All Status" IsSelected="True" />
                                    <ComboBoxItem Content="Pending Dispatch" />
                                    <ComboBoxItem Content="In Transit" />
                                    <ComboBoxItem Content="Delivered" />
                                </ComboBox>
                                <Button Content="↻" Background="{StaticResource ThemeGreen}" Foreground="White" BorderThickness="0" Width="26" Height="26" Margin="4,0" Cursor="Hand" Click="TrackingRefresh_Click" ToolTip="Clear Filters" />
                                <Button Content="✎" Background="#FF9800" Foreground="White" BorderThickness="0" Width="26" Height="26" Margin="4,0" Cursor="Hand" Click="OpenTrackingEntryForm_Click" ToolTip="Edit Selected" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DataGrid ItemsSource="{Binding Entries}" AutoGenerateColumns="False" CanUserAddRows="False" x:Name="TrackingLedgerGrid"
                                       ScrollViewer.HorizontalScrollBarVisibility="Visible" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                       VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Pixel"
                                      Background="White" BorderThickness="0" RowHeight="30" RowHeaderWidth="0" HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB" 
                                          RowBackground="White" FontSize="12" SelectionUnit="FullRow" IsReadOnly="True"
                                          MouseDoubleClick="TrackingGrid_MouseDoubleClick"
                                          RowDetailsVisibilityMode="Collapsed"
                                          SelectionChanged="TrackingLedgerGrid_SelectionChanged"
                                          ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="28">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="+" FontSize="10" Width="18" Height="18" Padding="0" BorderThickness="0" Background="Transparent" Foreground="#1565C0" Cursor="Hand"
                                                            Click="ToggleTrackingDetails_Click" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Sr." Binding="{Binding Sr}" Width="35" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Challan No." Binding="{Binding ChallanNo}" Width="100" FontWeight="SemiBold" />
                                        <DataGridTextColumn Header="Challan Date" Binding="{Binding ChallanDate, StringFormat=dd-MMM-yyyy}" Width="90" />
                                        <DataGridTextColumn Header="From" Binding="{Binding From}" Width="80" />
                                        <DataGridTextColumn Header="To" Binding="{Binding To}" Width="80" />
                                        <DataGridTextColumn Header="Vehicle No." Binding="{Binding VehicleNo}" Width="100" />
                                        <DataGridTextColumn Header="Driver Mob." Binding="{Binding DriverMobile}" Width="100" />
                                        <DataGridTextColumn Header="Dispatch Dt." Binding="{Binding DispatchDate, StringFormat=dd-MMM-yyyy}" Width="85" />
                                        <DataGridTextColumn Header="Disp. Time" Binding="{Binding DispatchTime}" Width="70" />
                                        <DataGridTextColumn Header="Delivered Dt." Binding="{Binding DeliveredDate, StringFormat=dd-MMM-yyyy}" Width="85" />
                                        <DataGridTextColumn Header="Delv. Time" Binding="{Binding DeliveredTime}" Width="70" />
                                        <DataGridTextColumn Header="Latest Report" Binding="{Binding LatestReport}" Width="180" Foreground="#E65100" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" FontWeight="SemiBold" />
                                    </DataGrid.Columns>
                                    <DataGrid.RowDetailsTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFF8E1" BorderBrush="#FFE0B2" BorderThickness="1" Padding="8,4">
                                                <StackPanel>
                                                    <TextBlock Text="Reporting Track History" FontSize="11" FontWeight="SemiBold" Foreground="#E65100" Margin="0,0,0,4" />
                                                    <ItemsControl ItemsSource="{Binding ReportTracks}" DisplayMemberPath="DisplayText" FontSize="11" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGrid.RowDetailsTemplate>
                                </DataGrid>
                            <Border Grid.Row="1" Background="White" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding FilteredEntriesCount, StringFormat='Records: {0}'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBox x:Name="QuickReportBox" Width="250" Height="26" FontSize="12" Padding="6,2" BorderBrush="#CCCCCC" BorderThickness="1"
                                                 Text="Enter report update..." GotFocus="QuickReportBox_GotFocus" VerticalContentAlignment="Center" Margin="0,0,8,0" />
                                        <Button Content="+" Background="{StaticResource ThemeBlue}" Foreground="White" BorderThickness="0" Width="26" Height="26" Cursor="Hand" Click="QuickAddReport_Click" ToolTip="Add Report" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                        </Grid>
                    </Grid>

            </Border>

        </Grid>

        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,6" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="3" Padding="6,2">
            <TextBlock x:Name="AppVersionText" Text="v -" FontSize="11" Foreground="#6B7280" Cursor="Hand" ToolTip="Click to check for updates" MouseLeftButtonUp="AppVersionText_MouseLeftButtonUp" />
        </Border>

    </Grid>

</Controls:MetroWindow>



